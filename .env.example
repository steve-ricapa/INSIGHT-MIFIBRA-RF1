# Base URL de la API InsightVM (normalmente termina en /api/3)
INSIGHTVM_BASE_URL=https://your-insightvm-host:3780/api/3

# Usuario de autenticación básica para InsightVM
INSIGHTVM_USER=admin

# Contraseña del usuario InsightVM
INSIGHTVM_PASSWORD=change-me

# Timeout por request HTTP (segundos)
INSIGHTVM_TIMEOUT=30

# Verificación SSL/TLS:
# - true: valida certificado (recomendado en producción)
# - false: desactiva validación (útil en lab/cert autosignado)
INSIGHTVM_VERIFY_SSL=false

# Intervalo entre ciclos pull (segundos). 3600 = 1 hora
PULL_INTERVAL_SECONDS=3600

# Tamaño de página para endpoints paginados de InsightVM
PAGE_SIZE=200

# Reintentos máximos por ciclo cuando falla la descarga
MAX_RETRIES=3

# Backoff base para reintentos exponenciales (segundos)
# Esperas resultantes: base, base*2, base*4, ...
RETRY_BACKOFF_SECONDS=1.0

# Severidades permitidas en payload filtrado (separadas por coma)
# Valores válidos: critical,high,medium,low,info,unknown
ALERT_SEVERITIES=critical,high

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Ruta del archivo de log rotativo
LOG_FILE=logs/integration.log

# Carpeta donde se guardan raw/filtered/meta por ejecución
PAYLOAD_DIR=payloads

# Habilita envío al backend de alarmas:
# - true: envía hallazgos filtrados al endpoint BACKEND_URL
# - false: solo guarda payloads locales
BACKEND_ENABLED=false

# URL completa del endpoint backend que recibe las alarmas por POST JSON
BACKEND_URL=https://10.208.232.208/txdxsecure/guarda_alarma.php

# Valor de negocio enviado en el campo JSON "Local"
# Ejemplo: "Mi Fibra"
BACKEND_LOCAL=Mi Fibra

# Texto base para construir el campo JSON "TipoAlarma"
# El sistema añade severidad/título del hallazgo al enviar
BACKEND_ALARM_TYPE=Alarma InsightVM

# Timeout HTTP hacia backend (segundos)
BACKEND_TIMEOUT=30

# Verificación SSL/TLS para backend:
# - true: valida certificado
# - false: omite validación (útil en redes internas/certificados no públicos)
BACKEND_VERIFY_SSL=false
